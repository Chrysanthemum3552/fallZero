<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/onboardingFragment">

    <!-- ───────── Global actions (SessionFlow 자동 진행용) ───────── -->
    <action android:id="@+id/action_global_preflight"
        app:destination="@id/preFlightFragment"
        app:popUpTo="@id/homeFragment" />
    <action android:id="@+id/action_global_exercise"
        app:destination="@id/exerciseFragment"
        app:popUpTo="@id/homeFragment" />
    <action android:id="@+id/action_global_exam"
        app:destination="@id/examFragment"
        app:popUpTo="@id/homeFragment" />
    <action android:id="@+id/action_global_exam_result"
        app:destination="@id/resultSurveyFragment"
        app:popUpTo="@id/homeFragment" />
    <action android:id="@+id/action_global_rest"
        app:destination="@id/restFragment"
        app:popUpTo="@id/homeFragment" />
    <action android:id="@+id/action_global_rotation"
        app:destination="@id/sideRotationFragment"
        app:popUpTo="@id/homeFragment" />
    <action android:id="@+id/action_global_chair_reposition"
        app:destination="@id/chairRepositionFragment"
        app:popUpTo="@id/homeFragment" />
    <action android:id="@+id/action_global_home"
        app:destination="@id/homeFragment"
        app:popUpTo="@id/homeFragment"
        app:popUpToInclusive="true" />

    <!-- ───────── 온보딩 플로우 (5단계: 성별 → 나이 → Q1 → Q2 → Q3) ───────── -->
    <fragment
        android:id="@+id/onboardingFragment"
        android:name="com.fallzero.app.ui.onboarding.OnboardingFragment"
        android:label="온보딩"
        tools:layout="@layout/fragment_onboarding">
        <action
            android:id="@+id/action_onboarding_to_gender"
            app:destination="@id/genderFragment" />
    </fragment>

    <fragment
        android:id="@+id/genderFragment"
        android:name="com.fallzero.app.ui.onboarding.GenderFragment"
        android:label="성별"
        tools:layout="@layout/fragment_gender">
        <action
            android:id="@+id/action_gender_to_age"
            app:destination="@id/ageFragment" />
    </fragment>

    <fragment
        android:id="@+id/ageFragment"
        android:name="com.fallzero.app.ui.onboarding.AgeFragment"
        android:label="나이"
        tools:layout="@layout/fragment_age">
        <action
            android:id="@+id/action_age_to_q1"
            app:destination="@id/steadiQ1Fragment" />
    </fragment>

    <fragment
        android:id="@+id/steadiQ1Fragment"
        android:name="com.fallzero.app.ui.onboarding.SteadiQ1Fragment"
        android:label="질문 1"
        tools:layout="@layout/fragment_steadi_q1">
        <action
            android:id="@+id/action_q1_to_q2"
            app:destination="@id/steadiQ2Fragment" />
    </fragment>

    <fragment
        android:id="@+id/steadiQ2Fragment"
        android:name="com.fallzero.app.ui.onboarding.SteadiQ2Fragment"
        android:label="질문 2"
        tools:layout="@layout/fragment_steadi_q2">
        <action
            android:id="@+id/action_q2_to_q3"
            app:destination="@id/steadiQ3Fragment" />
    </fragment>

    <fragment
        android:id="@+id/steadiQ3Fragment"
        android:name="com.fallzero.app.ui.onboarding.SteadiQ3Fragment"
        android:label="질문 3"
        tools:layout="@layout/fragment_steadi_q3">
        <action
            android:id="@+id/action_q3_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/onboardingFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- ───────── 사전 점검 (폰 직립 + 전신 감지) ───────── -->
    <fragment
        android:id="@+id/preFlightFragment"
        android:name="com.fallzero.app.ui.onboarding.PreFlightFragment"
        android:label="준비 단계"
        tools:layout="@layout/fragment_pre_flight" />

    <!-- 옆으로 회전 단계 -->
    <fragment
        android:id="@+id/sideRotationFragment"
        android:name="com.fallzero.app.ui.onboarding.SideRotationFragment"
        android:label="옆으로 돌아주세요"
        tools:layout="@layout/fragment_side_rotation" />

    <!-- 측면 의자 자세 잡기 (#1 앉아서 무릎 펴기 직전) -->
    <fragment
        android:id="@+id/chairRepositionFragment"
        android:name="com.fallzero.app.ui.onboarding.ChairRepositionFragment"
        android:label="의자에 앉아주세요"
        tools:layout="@layout/fragment_chair_reposition" />

    <!-- 휴식 카운트다운 -->
    <fragment
        android:id="@+id/restFragment"
        android:name="com.fallzero.app.ui.onboarding.RestFragment"
        android:label="휴식"
        tools:layout="@layout/fragment_rest" />

    <!-- ───────── 홈 ───────── -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.fallzero.app.ui.home.HomeFragment"
        android:label="홈"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_exercise_guide"
            app:destination="@id/exerciseGuideFragment" />
        <action
            android:id="@+id/action_home_to_exam"
            app:destination="@id/preFlightFragment" />
        <action
            android:id="@+id/action_home_to_report"
            app:destination="@id/reportFragment" />
        <action
            android:id="@+id/action_home_to_settings"
            app:destination="@id/settingsFragment" />
    </fragment>

    <!-- ───────── 검사 플로우 ───────── -->
    <fragment
        android:id="@+id/examFragment"
        android:name="com.fallzero.app.ui.exam.ExamFragment"
        android:label="낙상 위험 검사"
        tools:layout="@layout/fragment_exam" />

    <fragment
        android:id="@+id/examResultFragment"
        android:name="com.fallzero.app.ui.exam.ExamResultFragment"
        android:label="검사 결과 (legacy)"
        tools:layout="@layout/fragment_exam_result">
        <action
            android:id="@+id/action_result_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- ───────── 검사 결과 4페이지 (Survey → Balance → Chair → Final) ───────── -->
    <fragment
        android:id="@+id/resultSurveyFragment"
        android:name="com.fallzero.app.ui.exam.result.ResultSurveyFragment"
        android:label="검사 결과 1/4"
        tools:layout="@layout/fragment_result_survey">
        <action
            android:id="@+id/action_result_survey_to_balance"
            app:destination="@id/resultBalanceFragment" />
    </fragment>

    <fragment
        android:id="@+id/resultBalanceFragment"
        android:name="com.fallzero.app.ui.exam.result.ResultBalanceFragment"
        android:label="검사 결과 2/4"
        tools:layout="@layout/fragment_result_balance">
        <action
            android:id="@+id/action_result_balance_to_chair"
            app:destination="@id/resultChairFragment" />
    </fragment>

    <fragment
        android:id="@+id/resultChairFragment"
        android:name="com.fallzero.app.ui.exam.result.ResultChairFragment"
        android:label="검사 결과 3/4"
        tools:layout="@layout/fragment_result_chair">
        <action
            android:id="@+id/action_result_chair_to_final"
            app:destination="@id/resultFinalFragment" />
    </fragment>

    <fragment
        android:id="@+id/resultFinalFragment"
        android:name="com.fallzero.app.ui.exam.result.ResultFinalFragment"
        android:label="검사 결과 4/4"
        tools:layout="@layout/fragment_result_final">
        <action
            android:id="@+id/action_result_final_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- ───────── 운동 플로우 ───────── -->
    <fragment
        android:id="@+id/exerciseGuideFragment"
        android:name="com.fallzero.app.ui.exercise.ExerciseGuideFragment"
        android:label="운동 가이드"
        tools:layout="@layout/fragment_exercise_guide">
        <action
            android:id="@+id/action_guide_to_preview"
            app:destination="@id/exercisePreviewFragment" />
        <action
            android:id="@+id/action_guide_to_preflight"
            app:destination="@id/preFlightFragment" />
    </fragment>

    <fragment
        android:id="@+id/exercisePreviewFragment"
        android:name="com.fallzero.app.ui.exercise.ExercisePreviewFragment"
        android:label="운동 미리보기"
        tools:layout="@layout/fragment_exercise_preview">
        <action
            android:id="@+id/action_preview_to_preflight"
            app:destination="@id/preFlightFragment" />
    </fragment>

    <fragment
        android:id="@+id/exerciseFragment"
        android:name="com.fallzero.app.ui.exercise.ExerciseFragment"
        android:label="운동"
        tools:layout="@layout/fragment_exercise" />

    <!-- ───────── 보고서 (3페이지) ───────── -->
    <fragment
        android:id="@+id/reportFragment"
        android:name="com.fallzero.app.ui.report.ReportFragment"
        android:label="보고서 1"
        tools:layout="@layout/fragment_report">
        <action
            android:id="@+id/action_report_to_page2"
            app:destination="@id/reportPage2Fragment" />
    </fragment>

    <fragment
        android:id="@+id/reportPage2Fragment"
        android:name="com.fallzero.app.ui.report.ReportPage2Fragment"
        android:label="보고서 2"
        tools:layout="@layout/fragment_report_page2">
        <action
            android:id="@+id/action_report2_to_page1"
            app:destination="@id/reportFragment"
            app:popUpTo="@id/reportFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_report2_to_page3"
            app:destination="@id/reportPage3Fragment" />
    </fragment>

    <fragment
        android:id="@+id/reportPage3Fragment"
        android:name="com.fallzero.app.ui.report.ReportPage3Fragment"
        android:label="보고서 3"
        tools:layout="@layout/fragment_report_page3">
        <action
            android:id="@+id/action_report3_to_page2"
            app:destination="@id/reportPage2Fragment"
            app:popUpTo="@id/reportPage2Fragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_report3_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- ───────── 설정 ───────── -->
    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.fallzero.app.ui.settings.SettingsFragment"
        android:label="설정"
        tools:layout="@layout/fragment_settings" />

</navigation>
