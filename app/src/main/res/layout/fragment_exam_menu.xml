<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="20dp">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_back"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:text="← 뒤로"
        android:textSize="22sp"
        android:textColor="@color/text_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="낙상 위험 검사"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:id="@+id/tv_title"
        app:layout_constraintTop_toBottomOf="@id/btn_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="진행할 항목을 선택해주세요"
        android:textSize="18sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginTop="6dp"
        android:id="@+id/tv_subtitle"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 버튼 묶음: 남은 공간을 weight로 균등 분배 → 스크롤 없이 한 화면 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_full_exam"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1.4"
            android:text="전체 검사 (균형 + 의자 일어서기)"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/on_primary"
            app:backgroundTint="@color/primary"
            app:cornerRadius="14dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="단일 검사"
            android:textSize="15sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_balance_1"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="8dp"
            android:textColor="@color/text_primary"
            app:strokeColor="@color/primary"
            android:text="균형 1단계 · 두 발 나란히"
            android:textSize="19sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_balance_2"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="8dp"
            android:textColor="@color/text_primary"
            app:strokeColor="@color/primary"
            android:text="균형 2단계 · 반일렬"
            android:textSize="19sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_balance_3"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="8dp"
            android:textColor="@color/text_primary"
            app:strokeColor="@color/primary"
            android:text="균형 3단계 · 일렬"
            android:textSize="19sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_balance_4"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="8dp"
            android:textColor="@color/text_primary"
            app:strokeColor="@color/primary"
            android:text="균형 4단계 · 한 발 서기"
            android:textSize="19sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_chair_only"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            app:strokeColor="@color/primary"
            android:text="의자 일어서기 (30초)"
            android:textSize="19sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
