<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_step"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="4 / 4"
        android:textSize="20sp"
        android:textColor="#888888"
        android:gravity="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="종합 결과"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:singleLine="true"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_step"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 큰 위험군/안전군 뱃지 — 글자 너무 많으면 자동 축소 + singleLine으로 어색한 줄바꿈 방지 -->
    <TextView
        android:id="@+id/tv_risk_badge"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="48sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="32dp"
        android:singleLine="true"
        android:maxLines="1"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="24sp"
        android:autoSizeMaxTextSize="56sp"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintBottom_toTopOf="@id/tv_recommendation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="⚠ 낙상 위험군" />

    <!-- 권장 사항 -->
    <TextView
        android:id="@+id/tv_recommendation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4"
        android:background="#2A2A2A"
        android:padding="20dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/btn_home"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="3가지 차원 중 X개에서 위험 신호가 있어요. 운동을 시작해 보세요." />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_share_guardian"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="📤 보호자에게 자세한 결과 공유"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"
        app:cornerRadius="16dp"
        app:backgroundTint="#2A2A2A"
        android:textColor="#FFFFFF"
        app:strokeColor="#888888"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toTopOf="@id/btn_home"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_home"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:text="홈으로"
        android:textSize="28sp"
        android:textStyle="bold"
        android:enabled="false"
        android:layout_marginBottom="24dp"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
