<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- 메인 레이아웃 (상하 분리) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 상단 상태 바: 운동명/단계명 + 우측 카메라 전환 버튼 -->
        <LinearLayout
            android:id="@+id/layout_top_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#CC000000"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tv_exam_phase"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="@string/exam_title"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="#FFFF00"
                    android:gravity="center"
                    tools:text="균형 검사 1단계" />

                <!-- 카메라 전환 버튼 — 운동명 우측 끝, 다른 문구 안 가림 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_camera_flip"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="🔄"
                    android:textSize="22sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#33FFFFFF"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    app:cornerRadius="24dp" />
            </RelativeLayout>

            <ProgressBar
                android:id="@+id/progress_timer"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="10dp"
                android:max="30"
                android:progress="30"
                android:progressTint="#FFFF00"
                android:progressBackgroundTint="#444400"
                android:visibility="gone" />

        </LinearLayout>

        <!-- 카메라 영역 (전체 사용 — 사람 전신 보이게) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.camera.view.PreviewView
                android:id="@+id/preview_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <com.fallzero.app.ui.overlay.PoseOverlayView
                android:id="@+id/pose_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- 카메라 영역 위에 floating으로 카운트/타이머 표시 (작게, 우상단) -->
            <LinearLayout
                android:id="@+id/layout_center_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#CC000000"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="12dp">

                <TextView
                    android:id="@+id/tv_timer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="30"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#FFFF00"
                    android:gravity="center"
                    tools:text="28" />

                <TextView
                    android:id="@+id/tv_timer_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="4dp"
                    android:text="초"
                    android:textSize="16sp"
                    android:textColor="#FFE066" />

                <TextView
                    android:id="@+id/tv_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="14dp"
                    android:text="0"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#FFFF00"
                    android:gravity="center"
                    tools:text="5" />

                <TextView
                    android:id="@+id/tv_count_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="회"
                    android:textSize="16sp"
                    android:textColor="#FFE066"
                    android:layout_marginLeft="4dp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- (카메라 전환 버튼은 layout_top_bar 안 우측으로 이동 — 아래 참조) -->

            <!-- 카메라 영역 위 floating 큰 카운트다운 (3,2,1,시작!) — tv_count 대체 -->
            <TextView
                android:id="@+id/tv_big_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textSize="120sp"
                android:textStyle="bold"
                android:textColor="#FFFF00"
                android:shadowColor="#000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="6"
                android:visibility="gone"
                tools:text="3" />

            <!-- 시작 버튼 (자동 진행이라 보통 hidden) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_start_exam"
                android:layout_width="wrap_content"
                android:layout_height="64dp"
                android:layout_gravity="bottom|center"
                android:layout_marginBottom="32dp"
                android:text="@string/exam_start"
                android:textSize="24sp"
                android:textColor="#000000"
                android:visibility="gone"
                android:paddingHorizontal="32dp"
                app:backgroundTint="#FFFF00"
                app:cornerRadius="16dp" />

            <!-- 균형 검사 종료 버튼 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_balance_fail"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:layout_gravity="bottom|center"
                android:layout_marginBottom="32dp"
                android:text="@string/exam_balance_fail"
                android:textColor="#FFFF00"
                android:textSize="20sp"
                android:visibility="gone"
                android:paddingHorizontal="24dp"
                app:strokeColor="#FFFF00"
                app:strokeWidth="2dp"
                app:cornerRadius="16dp" />

        </FrameLayout>

    </LinearLayout>

    <!-- 일시정지 오버레이 -->
    <FrameLayout
        android:id="@+id/pause_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#A0000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#EE000000"
            android:paddingLeft="48dp"
            android:paddingRight="48dp"
            android:paddingTop="40dp"
            android:paddingBottom="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏸"
                android:textSize="64sp"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="잠시 멈춤"
                android:textSize="40sp"
                android:textStyle="bold"
                android:textColor="#FFFF00"
                android:gravity="center" />

            <TextView
                android:id="@+id/tv_pause_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="카메라 앞으로 와주세요"
                android:textSize="32sp"
                android:textColor="#FFE066"
                android:gravity="center" />

        </LinearLayout>
    </FrameLayout>

    <!-- 단계 안내 오버레이 -->
    <FrameLayout
        android:id="@+id/guidance_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F0000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- 단계 제목 -->
            <TextView
                android:id="@+id/tv_guidance_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="#FFFF00"
                android:gravity="center"
                android:background="#EE000000"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:text="1단계 · 두 발 나란히 서기" />

            <!-- 동영상 플레이스홀더 -->
            <FrameLayout
                android:id="@+id/video_placeholder"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:background="#22FFFF00"
                app:layout_constraintTop_toBottomOf="@id/tv_guidance_title"
                app:layout_constraintBottom_toTopOf="@id/tv_guidance_text"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="@string/guidance_video_placeholder"
                    android:textColor="#CCCC00"
                    android:textSize="28sp" />

                <!-- 카운트다운 -->
                <TextView
                    android:id="@+id/tv_guidance_countdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:textSize="120sp"
                    android:textStyle="bold"
                    android:textColor="#FFFF00"
                    android:gravity="center"
                    android:visibility="gone"
                    tools:text="3" />
            </FrameLayout>

            <!-- 단계 설명 (하단) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#EE000000"
                android:paddingLeft="24dp"
                android:paddingRight="24dp"
                android:paddingTop="20dp"
                android:paddingBottom="28dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/tv_guidance_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="28sp"
                    android:lineSpacingMultiplier="1.6"
                    android:textColor="#FFFF00"
                    android:gravity="center"
                    tools:text="양쪽 발을 나란히 모아 붙이고 10초 동안 그대로 서 있으면 됩니다." />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>

</FrameLayout>