<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Pose Skeleton Overlay -->
    <com.fallzero.app.ui.overlay.PoseOverlayView
        android:id="@+id/pose_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Phase title (현재 검사 단계) -->
    <TextView
        android:id="@+id/tv_exam_phase"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/exam_title"
        android:textSize="18sp"
        android:textColor="@android:color/white"
        android:background="#CC000000"
        android:padding="10dp"
        android:gravity="center"
        android:layout_marginTop="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 의자 검사: 남은 시간 (초) -->
    <TextView
        android:id="@+id/tv_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="30"
        android:textSize="80sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 의자 검사: 횟수 or 균형 유지 초 -->
    <TextView
        android:id="@+id/tv_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textSize="48sp"
        android:textStyle="bold"
        android:textColor="#FFFFC107"
        android:background="#80000000"
        android:padding="12dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/btn_start_exam"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp" />

    <!-- 시작 버튼 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_start_exam"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/exam_start"
        android:textSize="18sp"
        android:paddingHorizontal="40dp"
        android:layout_marginBottom="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 균형 검사: "이 단계 종료" 버튼 (못 버틸 때) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_balance_fail"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/exam_balance_fail"
        android:textColor="@android:color/white"
        android:visibility="gone"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/btn_start_exam"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
