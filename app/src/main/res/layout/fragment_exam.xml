<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/layout_top_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#CC000000"
            android:paddingLeft="16dp" android:paddingRight="16dp"
            android:paddingTop="12dp" android:paddingBottom="12dp">

            <TextView
                android:id="@+id/tv_exam_phase"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/exam_title"
                android:breakStrategy="simple" android:hyphenationFrequency="none"
                android:textSize="32sp" android:textStyle="bold"
                android:textColor="#FFFF00" android:gravity="center"
                tools:text="균형 검사 1단계" />

            <ProgressBar
                android:id="@+id/progress_timer"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent" android:layout_height="8dp"
                android:layout_marginTop="10dp"
                android:max="30" android:progress="30"
                android:progressTint="#FFFF00" android:progressBackgroundTint="#444400"
                android:visibility="gone" />

        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="100">

            <androidx.camera.view.PreviewView
                android:id="@+id/preview_view"
                android:scaleX="-1"
                app:implementationMode="compatible"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <com.fallzero.app.ui.overlay.PoseOverlayView
                android:id="@+id/pose_overlay"
                android:scaleX="-1"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <com.fallzero.app.ui.overlay.GuideBarView
                android:id="@+id/guide_bar"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:layout_marginTop="80dp" android:layout_marginBottom="40dp"
                android:visibility="gone" />

            <com.fallzero.app.ui.overlay.BalanceBubbleView
                android:id="@+id/guide_bubble"
                android:layout_width="320dp" android:layout_height="320dp"
                android:layout_gravity="center"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btn_camera_flip"
                android:layout_width="56dp" android:layout_height="56dp"
                android:layout_gravity="top|end" android:layout_margin="12dp"
                android:background="#80000000" android:contentDescription="카메라 전환"
                android:padding="8dp" android:src="@android:drawable/ic_menu_camera" />

            <!-- 좌상단: 남은시간 원형 게이지 (게이지가 30초→0초로 줄어듦) -->
            <FrameLayout
                android:id="@+id/layout_corner_count"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_marginTop="80dp" android:layout_marginStart="12dp"
                android:visibility="gone">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/progress_corner_timer"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:max="30" android:progress="30"
                    app:indicatorSize="120dp"
                    app:trackThickness="12dp"
                    app:trackCornerRadius="6dp"
                    app:indicatorColor="#FFFF00"
                    app:trackColor="#44FFFF00" />

                <LinearLayout
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical" android:gravity="center">

                    <TextView
                        android:id="@+id/tv_corner_timer"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center" android:text=""
                        android:textSize="40sp" android:textStyle="bold" android:textColor="#FFFF00"
                        android:shadowColor="#000000" android:shadowDx="2" android:shadowDy="2"
                        android:shadowRadius="4"
                        tools:text="25" />

                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center" android:text="남은시간"
                        android:textSize="14sp" android:textColor="#FFE066"
                        android:shadowColor="#000000" android:shadowDx="2" android:shadowDy="2"
                        android:shadowRadius="4" />
                </LinearLayout>
            </FrameLayout>

            <!-- 좌하단: 현재 일어선 횟수 -->
            <TextView
                android:id="@+id/tv_corner_count"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="12dp" android:layout_marginBottom="24dp"
                android:text="" android:textSize="40sp" android:textStyle="bold"
                android:textColor="#FFFF00" android:background="#CC000000"
                android:paddingLeft="20dp" android:paddingRight="20dp"
                android:paddingTop="10dp" android:paddingBottom="10dp"
                android:visibility="gone"
                tools:text="5회" />

            <VideoView
                android:id="@+id/video_chair_guide"
                android:layout_width="160dp" android:layout_height="90dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="12dp" android:layout_marginBottom="12dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_floating_feedback"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="16dp"
                android:background="#CC000000"
                android:paddingLeft="20dp" android:paddingRight="20dp"
                android:paddingTop="10dp" android:paddingBottom="10dp"
                android:textSize="22sp" android:textStyle="bold" android:textColor="#FFFFFF"
                android:gravity="center" android:lineSpacingMultiplier="1.2"
                android:visibility="gone"
                tools:text="잘 하고 있어요!" />

            <View
                android:id="@+id/v_countdown_dim"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:background="#CC000000"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_big_countdown"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:breakStrategy="simple" android:hyphenationFrequency="none"
                android:textSize="160sp" android:textStyle="bold"
                android:textColor="#FFFFFF00" android:gravity="center"
                android:visibility="gone"
                tools:text="3" />

        </FrameLayout>

        <LinearLayout
            android:id="@+id/layout_center_info"
            android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="0" android:visibility="gone"
            android:orientation="vertical" android:gravity="center"
            android:background="#EE000000"
            android:paddingLeft="24dp" android:paddingRight="24dp"
            android:paddingTop="8dp" android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_timer"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="" android:breakStrategy="simple" android:hyphenationFrequency="none"
                    android:textSize="24sp" android:textStyle="bold"
                    android:textColor="#FFFF00" android:gravity="center"
                    tools:text="의자 앞에 가만히 서주세요" />

                <TextView
                    android:id="@+id/tv_timer_label"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginLeft="8dp" android:text=""
                    android:breakStrategy="simple" android:hyphenationFrequency="none"
                    android:textSize="18sp" android:textColor="#FFE066" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_count"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="" android:breakStrategy="simple" android:hyphenationFrequency="none"
                android:textSize="24sp" android:textStyle="bold" android:textColor="#FFFF00"
                android:gravity="center" android:layout_marginTop="4dp"
                android:lineSpacingMultiplier="1.2"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="16sp" android:autoSizeMaxTextSize="24sp"
                android:autoSizeStepGranularity="2sp" android:maxLines="3"
                tools:text="잘하고 있어요!" />

            <TextView
                android:id="@+id/tv_count_label"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="회" android:breakStrategy="simple" android:hyphenationFrequency="none"
                android:textSize="32sp" android:textColor="#FFE066"
                android:gravity="center" android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_start_exam"
                android:layout_width="match_parent" android:layout_height="72dp"
                android:text="@string/exam_start" android:textSize="32sp"
                android:textColor="#000000" android:layout_marginTop="16dp"
                android:visibility="gone"
                app:backgroundTint="#FFFF00" app:cornerRadius="16dp" />

        </LinearLayout>

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_balance_fail"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="280dp" android:layout_height="56dp"
        android:text="@string/exam_balance_fail" android:textColor="#FFFF00"
        android:textSize="20sp" android:visibility="gone"
        android:layout_gravity="bottom|center_horizontal" android:layout_marginBottom="24dp"
        android:backgroundTint="#CC000000"
        app:strokeColor="#FFFF00" app:strokeWidth="2dp" app:cornerRadius="16dp" />

    <!-- 일시정지 오버레이 -->
    <FrameLayout
        android:id="@+id/pause_overlay"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#A0000000" android:clickable="true" android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center" android:orientation="vertical" android:gravity="center"
            android:background="#EE000000"
            android:paddingLeft="48dp" android:paddingRight="48dp"
            android:paddingTop="40dp" android:paddingBottom="40dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="||" android:textSize="64sp" android:gravity="center" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="16dp" android:text="잠시 멈춤"
                android:textSize="40sp" android:textStyle="bold"
                android:textColor="#FFFF00" android:gravity="center" />

            <TextView
                android:id="@+id/tv_pause_message"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="12dp" android:text="카메라 앞으로 와주세요"
                android:breakStrategy="simple" android:hyphenationFrequency="none"
                android:textSize="32sp" android:textColor="#FFE066" android:gravity="center" />

        </LinearLayout>
    </FrameLayout>

    <!-- 단계 안내 오버레이 -->
    <FrameLayout
        android:id="@+id/guidance_overlay"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#FF000000" android:clickable="true" android:focusable="true"
        android:visibility="gone">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/tv_guidance_title"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginLeft="20dp" android:layout_marginRight="20dp"
                android:breakStrategy="simple" android:hyphenationFrequency="none"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="16sp" android:autoSizeMaxTextSize="32sp"
                android:autoSizeStepGranularity="2sp"
                android:textSize="32sp" android:textStyle="bold" android:textColor="#FFFF00"
                android:gravity="center" android:background="#EE000000"
                android:paddingLeft="16dp" android:paddingRight="16dp"
                android:paddingTop="10dp" android:paddingBottom="10dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:text="1단계 · 두 발 나란히 서기" />

            <FrameLayout
                android:id="@+id/video_placeholder"
                android:layout_width="0dp" android:layout_height="0dp"
                android:layout_marginTop="6dp"
                android:layout_marginLeft="16dp" android:layout_marginRight="20dp"
                app:layout_constraintTop_toBottomOf="@id/tv_guidance_title"
                app:layout_constraintBottom_toTopOf="@id/layout_guidance_text"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/tv_video_placeholder"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="center" android:gravity="center"
                    android:text="@string/guidance_video_placeholder"
                    android:textColor="#CCCC00" android:breakStrategy="simple"
                    android:hyphenationFrequency="none" android:textSize="28sp" />

                <TextView
                    android:id="@+id/tv_guidance_countdown"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="center" android:breakStrategy="simple"
                    android:hyphenationFrequency="none" android:textSize="120sp"
                    android:textStyle="bold" android:textColor="#FFFF00"
                    android:gravity="center" android:visibility="gone"
                    tools:text="3" />
            </FrameLayout>

            <TextureView
                android:id="@+id/video_chair_guidance"
                android:layout_width="0dp" android:layout_height="0dp"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" ></TextureView>

            <ImageView
                android:id="@+id/iv_chair_front_pose"
                android:layout_width="0dp" android:layout_height="0dp"
                android:scaleType="centerCrop" android:visibility="gone"
                android:contentDescription="의자 앞에 정면을 바라보고 서주세요"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- 막대기 설명용: 안내영상 위에 겹쳐 오른쪽에 막대기 표시 (검사 막대기 설명) -->
            <com.fallzero.app.ui.overlay.GuideBarView
                android:id="@+id/guide_bar_sim"
                android:layout_width="0dp" android:layout_height="0dp"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <LinearLayout
                android:id="@+id/layout_guidance_text"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="#EE000000"
                android:paddingLeft="24dp" android:paddingRight="24dp"
                android:paddingTop="12dp" android:paddingBottom="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/tv_chair_subtitle"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="" android:textSize="32sp" android:textStyle="bold"
                    android:textColor="#FFFF00" android:background="#FF000000"
                    android:gravity="center"
                    android:paddingTop="12dp" android:paddingBottom="12dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"
                    tools:text="이제 천천히 앉았다 일어서세요" />

                <TextView
                    android:id="@+id/tv_guidance_text"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:breakStrategy="simple" android:hyphenationFrequency="none"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="14sp" android:autoSizeMaxTextSize="22sp"
                    android:autoSizeStepGranularity="2sp"
                    android:textSize="22sp" android:lineSpacingMultiplier="1.3"
                    android:textColor="#FFFF00" android:gravity="center"
                    tools:text="양쪽 발을 나란히 모아 붙이고 10초 동안 그대로 서 있으면 됩니다." />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!--
            [추가] 발 이미지 전환 안내 오버레이 (반일렬서기 / 일렬서기 전용)
            - 영상 5초 시점에 코드로 VISIBLE, 약 2.5초 후 GONE
            - 텍스트 크기/내용: tv_foot_guide_text 속성에서 수정
        -->
        <FrameLayout
            android:id="@+id/foot_guide_overlay"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:background="#BB000000"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_foot_guide_text"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="40dp" android:layout_marginEnd="40dp"
                android:text="다음 화면은\n위에서 봤을 때\n발 모양입니다.\n참고하세요"
                android:textSize="44sp" android:textStyle="bold" android:textColor="#FFFF00"
                android:gravity="center" android:lineSpacingMultiplier="1.3"
                tools:text="다음 화면은\n위에서 봤을 때\n발 모양입니다.\n참고하세요" />

        </FrameLayout>

        <!--
            [추가] 검사 안내 영상 자막 오버레이 (exercise와 동일 스타일)
            VideoView를 담은 ConstraintLayout 다음에 선언 -> z-order 상 위에 렌더링
            TTS 발화 중 해당 구간 영상 위에 큰 노란 텍스트 표시
        -->
        <FrameLayout
            android:id="@+id/exam_guide_text_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#55000000"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_exam_guide_line_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="28dp"
                android:layout_marginEnd="28dp"
                android:textSize="52sp"
                android:maxLines="2"
                android:breakStrategy="high_quality"
                android:hyphenationFrequency="none"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="24sp"
                android:autoSizeMaxTextSize="56sp"
                android:autoSizeStepGranularity="2sp"
                android:textStyle="bold"
                android:textColor="#FFFF00"
                android:gravity="center"
                android:lineSpacingMultiplier="1.2"
                android:shadowColor="#000000"
                android:shadowDx="4"
                android:shadowDy="4"
                android:shadowRadius="8"
                tools:text="팔 교차" />

        </FrameLayout>

    </FrameLayout>

</FrameLayout>