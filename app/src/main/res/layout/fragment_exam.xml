<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/layout_top_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#CC000000"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/tv_exam_phase"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/exam_title"
                android:breakStrategy="simple"
                android:hyphenationFrequency="none"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#FFFF00"
                android:gravity="center"
                tools:text="균형 검사 1단계" />

            <ProgressBar
                android:id="@+id/progress_timer"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="10dp"
                android:max="30"
                android:progress="30"
                android:progressTint="#FFFF00"
                android:progressBackgroundTint="#444400"
                android:visibility="gone" />

        </LinearLayout>

        <!-- 카메라 영역 (55%) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="55">

            <androidx.camera.view.PreviewView
                android:id="@+id/preview_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <com.fallzero.app.ui.overlay.PoseOverlayView
                android:id="@+id/pose_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <ImageButton
                android:id="@+id/btn_camera_flip"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="top|end"
                android:layout_margin="12dp"
                android:background="#80000000"
                android:contentDescription="카메라 전환"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_camera" />

            <TextView
                android:id="@+id/tv_big_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:breakStrategy="simple"
                android:hyphenationFrequency="none"
                android:textSize="160sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF00"
                android:gravity="center"
                android:visibility="gone"
                tools:text="3" />

        </FrameLayout>

        <!-- 하단 정보 영역 (45%) -->
        <LinearLayout
            android:id="@+id/layout_center_info"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="45"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#EE000000"
            android:paddingLeft="24dp"
            android:paddingRight="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- 타이머 행: tv_timer_label은 ExamFragment에서 동적으로 설정 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_timer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="30"
                    android:breakStrategy="simple"
                    android:hyphenationFrequency="none"
                    android:textSize="80sp"
                    android:textStyle="bold"
                    android:textColor="#FFFF00"
                    android:gravity="center"
                    tools:text="28" />

                <!-- 기본값 비움: ExamFragment에서 상황에 맞게 설정
                     - 검사 중: "초 남음"
                     - 완료 시: "" (숨김) -->
                <TextView
                    android:id="@+id/tv_timer_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="8dp"
                    android:text=""
                    android:breakStrategy="simple"
                    android:hyphenationFrequency="none"
                    android:textSize="32sp"
                    android:textColor="#FFE066" />

            </LinearLayout>

            <!-- 상태 메시지 / 횟수 -->
            <TextView
                android:id="@+id/tv_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:breakStrategy="simple"
                android:hyphenationFrequency="none"
                android:textSize="40sp"
                android:textStyle="bold"
                android:textColor="#FFFF00"
                android:gravity="center"
                android:layout_marginTop="8dp"
                android:lineSpacingMultiplier="1.3"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="16sp"
                android:autoSizeMaxTextSize="40sp"
                android:autoSizeStepGranularity="2sp"
                android:maxLines="3"
                tools:text="잘하고 있어요!" />

            <TextView
                android:id="@+id/tv_count_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="회"
                android:breakStrategy="simple"
                android:hyphenationFrequency="none"
                android:textSize="32sp"
                android:textColor="#FFE066"
                android:gravity="center"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_start_exam"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:text="@string/exam_start"
                android:textSize="32sp"
                android:textColor="#000000"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:backgroundTint="#FFFF00"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_balance_fail"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="@string/exam_balance_fail"
                android:textColor="#FFFF00"
                android:textSize="28sp"
                android:visibility="gone"
                android:layout_marginTop="12dp"
                app:strokeColor="#FFFF00"
                app:strokeWidth="2dp"
                app:cornerRadius="16dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- 일시정지 오버레이 -->
    <FrameLayout
        android:id="@+id/pause_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#A0000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#EE000000"
            android:paddingLeft="48dp"
            android:paddingRight="48dp"
            android:paddingTop="40dp"
            android:paddingBottom="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="||"
                android:breakStrategy="simple"
                android:hyphenationFrequency="none"
                android:textSize="64sp"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="잠시 멈춤"
                android:breakStrategy="simple"
                android:hyphenationFrequency="none"
                android:textSize="40sp"
                android:textStyle="bold"
                android:textColor="#FFFF00"
                android:gravity="center" />

            <TextView
                android:id="@+id/tv_pause_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="카메라 앞으로 와주세요"
                android:breakStrategy="simple"
                android:hyphenationFrequency="none"
                android:textSize="32sp"
                android:textColor="#FFE066"
                android:gravity="center" />

        </LinearLayout>
    </FrameLayout>

    <!-- 단계 안내 오버레이 -->
    <FrameLayout
        android:id="@+id/guidance_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F0000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/tv_guidance_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:breakStrategy="simple"
                android:hyphenationFrequency="none"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="16sp"
                android:autoSizeMaxTextSize="32sp"
                android:autoSizeStepGranularity="2sp"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#FFFF00"
                android:gravity="center"
                android:background="#EE000000"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:text="1단계 · 두 발 나란히 서기" />

            <FrameLayout
                android:id="@+id/video_placeholder"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="6dp"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="20dp"
                android:background="#22FFFF00"
                app:layout_constraintTop_toBottomOf="@id/tv_guidance_title"
                app:layout_constraintBottom_toTopOf="@id/tv_guidance_text"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="@string/guidance_video_placeholder"
                    android:textColor="#CCCC00"
                    android:breakStrategy="simple"
                    android:hyphenationFrequency="none"
                    android:textSize="28sp" />

                <TextView
                    android:id="@+id/tv_guidance_countdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:breakStrategy="simple"
                    android:hyphenationFrequency="none"
                    android:textSize="120sp"
                    android:textStyle="bold"
                    android:textColor="#FFFF00"
                    android:gravity="center"
                    android:visibility="gone"
                    tools:text="3" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#EE000000"
                android:paddingLeft="24dp"
                android:paddingRight="24dp"
                android:paddingTop="12dp"
                android:paddingBottom="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/tv_guidance_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:breakStrategy="simple"
                    android:hyphenationFrequency="none"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="14sp"
                    android:autoSizeMaxTextSize="22sp"
                    android:autoSizeStepGranularity="2sp"
                    android:textSize="22sp"
                    android:lineSpacingMultiplier="1.3"
                    android:textColor="#FFFF00"
                    android:gravity="center"
                    tools:text="양쪽 발을 나란히 모아 붙이고 10초 동안 그대로 서 있으면 됩니다." />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>

</FrameLayout>