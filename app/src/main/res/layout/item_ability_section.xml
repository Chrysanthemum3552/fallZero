<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <!-- 헤더: 운동명 + PRB -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tv_ex_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:breakStrategy="simple"
                android:hyphenationFrequency="none"
                tools:text="무릎 펴기" />
        </LinearLayout>

        <!-- 비어있을 때 (records 없음) — 가운데 안내. RecyclerView/page indicator는 GONE. -->
        <TextView
            android:id="@+id/tv_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:visibility="gone"
            tools:text="⚪ 아직 한 번도 안 해 보셨어요" />

        <!-- 좌우 스와이프 — 1 페이지 = 1 record. PagerSnapHelper로 스냅. -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_records"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:overScrollMode="never" />

        <!-- 페이지 인디케이터 — "최신 ◀ 2 / 5 ▶ 오래된" -->
        <TextView
            android:id="@+id/tv_page_indicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:paddingTop="6dp"
            tools:text="최신 ◀ 1 / 5 ▶ 오래된" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
