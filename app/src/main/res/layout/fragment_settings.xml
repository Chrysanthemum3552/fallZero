<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:text="← 뒤로"
            android:textSize="22sp"
            android:textColor="@color/text_primary"
            android:layout_marginStart="-12dp"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:breakStrategy="simple"
            android:hyphenationFrequency="none"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="28dp" />

        <!-- 알림 설정 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="알림"
            android:breakStrategy="simple"
            android:hyphenationFrequency="none"
            android:textSize="18sp"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="28dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="운동 알림"
                android:breakStrategy="simple"
                android:hyphenationFrequency="none"
                android:textSize="22sp"
                android:textColor="@color/text_primary" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/sw_notification"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- 내 정보 수정 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="내 정보"
            android:breakStrategy="simple"
            android:hyphenationFrequency="none"
            android:textSize="18sp"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <!-- 성별 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="성별"
                android:breakStrategy="simple"
                android:hyphenationFrequency="none"
                android:textSize="22sp"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggle_gender"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_male"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="52dp"
                    android:text="남성"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary"
                    app:strokeColor="@color/primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_female"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="52dp"
                    android:text="여성"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary"
                    app:strokeColor="@color/primary" />
            </com.google.android.material.button.MaterialButtonToggleGroup>
        </LinearLayout>

        <!-- 나이 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="28dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="나이"
                android:breakStrategy="simple"
                android:hyphenationFrequency="none"
                android:textSize="22sp"
                android:textColor="@color/text_primary" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                app:boxBackgroundMode="outline">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_age"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textSize="20sp"
                    android:hint="세"
                    android:gravity="center" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_profile"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="정보 저장"
            android:textSize="22sp"
            android:textColor="@color/on_primary"
            android:layout_marginBottom="36dp"
            app:backgroundTint="@color/primary" />

        <!-- 화면 표시 옵션 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="화면 표시"
            android:textSize="18sp"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="기준점 가이드"
                android:textSize="20sp"
                android:textColor="@color/text_primary" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/sw_show_guide"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ON 시 운동·검사 중 &quot;어디까지 해야 할지&quot; 게이지로 표시됩니다."
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:lineSpacingExtra="2dp"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="관절 점 표시"
                android:textSize="20sp"
                android:textColor="@color/text_primary" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/sw_show_skeleton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ON 시 카메라 화면에 33개 관절 위치 + 연결선이 표시됩니다."
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:lineSpacingExtra="2dp"
            android:layout_marginBottom="32dp" />

        <!-- 개발자 옵션 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="개발자 옵션"
            android:breakStrategy="simple"
            android:hyphenationFrequency="none"
            android:textSize="18sp"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="디버그 모드"
                android:breakStrategy="simple"
                android:hyphenationFrequency="none"
                android:textSize="20sp"
                android:textColor="@color/text_primary" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/sw_debug_mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ON 시 운동 화면에 수동 카운트 +1 버튼이 표시됩니다."
            android:breakStrategy="simple"
            android:hyphenationFrequency="none"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:lineSpacingExtra="2dp"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="안내 스킵"
                android:breakStrategy="simple"
                android:hyphenationFrequency="none"
                android:textSize="20sp"
                android:textColor="@color/text_primary" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/sw_skip_guidance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ON 시 사전 점검 및 안내를 건너뛰고 즉시 측정을\n시작합니다."
            android:breakStrategy="simple"
            android:hyphenationFrequency="none"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:lineSpacingExtra="2dp"
            android:layout_marginBottom="16dp" />

        <!-- 음성 길이 측정 (TTS 발화 시간 측정 도구) — 배포 시 제거 예정 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="음성 길이 측정"
            android:textSize="20sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="대사를 입력하고 측정을 누르면 0.75배속 TTS로 읽어주고 소요 시간을 표시합니다."
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:lineSpacingExtra="2dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_tts_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="3"
            android:maxLines="6"
            android:gravity="top|start"
            android:inputType="textMultiLine"
            android:hint="여기에 대사를 입력하세요"
            android:textSize="16sp"
            android:padding="12dp"
            android:background="#22000000"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_tts_measure"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="측정"
            android:textSize="18sp"
            android:textColor="@color/on_primary"
            android:layout_marginBottom="8dp"
            app:backgroundTint="@color/primary" />

        <TextView
            android:id="@+id/tv_tts_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="결과: —"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="32dp"
            tools:text="결과: 2.85초" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_reset_onboarding"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="온보딩 다시 하기"
            android:textSize="18sp"
            android:textColor="#FF5252"
            app:strokeColor="#FF5252"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_reset_calibration"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="운동 연습 다시 하기"
            android:textSize="18sp"
            android:textColor="#FFA726"
            app:strokeColor="#FFA726"
            android:layout_marginBottom="12dp" />

        <!-- 시연용: 진급 시연 더미 삽입 (각 운동 깨끗한 더미 2개 + 진급단계 1 리셋) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_insert_dummy"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="시연용 더미 2개씩 삽입"
            android:textSize="18sp"
            android:textColor="#42A5F5"
            app:strokeColor="#42A5F5"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="모든 운동에 '깨끗한 완료' 기록을 2개씩 넣고 진급단계를 1로 초기화합니다. 시연 당일 각 운동을 1번만 깨끗이 하면 진급이 표시됩니다."
            android:breakStrategy="simple"
            android:hyphenationFrequency="none"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:lineSpacingExtra="2dp"
            android:layout_marginBottom="32dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/text_secondary"
            android:alpha="0.3"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="시스템 정보"
            android:breakStrategy="simple"
            android:hyphenationFrequency="none"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_pose_model"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="포즈 인식 모델: 확인 중..."
            android:breakStrategy="simple"
            android:hyphenationFrequency="none"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="32dp"
            tools:text="포즈 인식 모델: HEAVY (가장 정확)" />

    </LinearLayout>
</ScrollView>