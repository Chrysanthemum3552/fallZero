<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.fallzero.app.ui.overlay.PoseOverlayView
        android:id="@+id/pose_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 가이드 bar (운동 진행도 시각화 — 수직/수평 통합).
         상단 UI(btn_stop, tv_count, tv_exercise_name) + 하단 디버그 버튼 안 가리게 margin. -->
    <com.fallzero.app.ui.overlay.GuideBarView
        android:id="@+id/guide_bar"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="140dp"
        android:layout_marginBottom="80dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 가이드 ring (균형 운동 #8 전용) — 사용자 명시: 거대한 원형 링 + 가운데 큰 노란 숫자 -->
    <com.fallzero.app.ui.overlay.BalanceBubbleView
        android:id="@+id/guide_bubble"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_marginTop="80dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 상단 운동명 -->
    <TextView
        android:id="@+id/tv_exercise_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:textColor="#FFFF00"
        android:background="#CC000000"
        android:padding="10dp"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/btn_camera_flip"
        app:layout_constraintEnd_toStartOf="@id/btn_stop" />

    <!-- 카운트 표시 -->
    <TextView
        android:id="@+id/tv_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 / 0"
        android:breakStrategy="simple"
        android:hyphenationFrequency="none"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFFF00"
        android:background="#CC000000"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="12dp"
        app:layout_constraintTop_toBottomOf="@id/btn_stop"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 카메라 전환 버튼 (좌상단) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_camera_flip"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="12dp"
        android:text="🔄"
        android:textSize="22sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#80000000"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:padding="0dp"
        app:cornerRadius="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 큰 카운트다운 -->
    <TextView
        android:id="@+id/tv_big_countdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:breakStrategy="simple"
        android:hyphenationFrequency="none"
        android:textSize="120sp"
        android:textStyle="bold"
        android:textColor="#FFFF00"
        android:shadowColor="#000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="6"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="3" />

    <!-- 자세 피드백 floating (사용자 명시 7번): 잘 하면 초록 ✓, 잘못이면 노란 메시지.
         반투명 검정 배경으로 가독성 확보. -->
    <TextView
        android:id="@+id/tv_error_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:breakStrategy="simple"
        android:hyphenationFrequency="none"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFF00"
        android:background="#CC000000"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.2"
        android:visibility="gone"
        android:layout_marginBottom="120dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 디버그 +1 버튼 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_debug_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DEBUG +1"
        android:textSize="14sp"
        android:visibility="gone"
        android:backgroundTint="#80FF9800"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 중지 버튼 (우상단) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_stop"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="12dp"
        android:text="✕"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FF5252"
        android:backgroundTint="#80000000"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:padding="0dp"
        app:cornerRadius="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 세션 완료 오버레이 -->
    <FrameLayout
        android:id="@+id/session_complete_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#F0000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingLeft="32dp"
            android:paddingRight="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="★"
                android:breakStrategy="simple"
                android:hyphenationFrequency="none"
                android:textSize="80sp"
                android:textColor="#FFFF00"
                android:gravity="center" />

            <TextView
                android:id="@+id/tv_session_complete_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="오늘 운동을 모두 마치셨어요!"
                android:breakStrategy="simple"
                android:hyphenationFrequency="none"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFF00"
                android:gravity="center" />

            <TextView
                android:id="@+id/tv_session_complete_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="수고하셨어요. 잠시 후 홈으로 돌아갑니다."
                android:breakStrategy="simple"
                android:hyphenationFrequency="none"
                android:textSize="20sp"
                android:textColor="#FFE066"
                android:gravity="center" />
        </LinearLayout>
    </FrameLayout>

    <!-- 일시정지 오버레이 -->
    <FrameLayout
        android:id="@+id/pause_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#A0000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏸"
                android:breakStrategy="simple"
                android:hyphenationFrequency="none"
                android:textSize="64sp"
                android:gravity="center" />

            <TextView
                android:id="@+id/tv_pause_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="카메라 앞으로 와주세요"
                android:breakStrategy="simple"
                android:hyphenationFrequency="none"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFF00"
                android:gravity="center" />
        </LinearLayout>
    </FrameLayout>

    <!-- 안내 오버레이 -->
    <FrameLayout
        android:id="@+id/guidance_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#F0000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/tv_guidance_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:breakStrategy="simple"
                android:hyphenationFrequency="none"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="16sp"
                android:autoSizeMaxTextSize="32sp"
                android:autoSizeStepGranularity="2sp"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#FFFF00"
                android:gravity="center"
                android:background="#CC000000"
                android:padding="12dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:text="옆으로 다리 들기" />

            <FrameLayout
                android:id="@+id/video_placeholder"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                app:layout_constraintTop_toBottomOf="@id/tv_guidance_title"
                app:layout_constraintBottom_toTopOf="@id/tv_guidance_text"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- "안내 영상" 큰 텍스트 / 영상 placeholder — 운동 안내 시작 시 텍스트 → 영상 -->
                <TextView
                    android:id="@+id/tv_video_placeholder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="@string/guidance_video_placeholder"
                    android:textColor="#CCCC00"
                    android:breakStrategy="simple"
                    android:hyphenationFrequency="none"
                    android:textSize="20sp"
                    android:visibility="gone" />

                <!-- 운동별 안내 영상 — 사용자 명시: 운동 진입 직후 placeholder 영상 -->
                <VideoView
                    android:id="@+id/video_exercise_guide"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_guidance_countdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:breakStrategy="simple"
                    android:hyphenationFrequency="none"
                    android:textSize="120sp"
                    android:textStyle="bold"
                    android:textColor="#FFFF00"
                    android:gravity="center"
                    android:visibility="gone"
                    tools:text="3" />
            </FrameLayout>

            <TextView
                android:id="@+id/tv_guidance_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:breakStrategy="simple"
                android:hyphenationFrequency="none"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="14sp"
                android:autoSizeMaxTextSize="22sp"
                android:autoSizeStepGranularity="2sp"
                android:textSize="22sp"
                android:lineSpacingMultiplier="1.4"
                android:textColor="#FFFF00"
                android:gravity="center"
                android:background="#CC000000"
                android:padding="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:text="옆으로 다리 들기 운동입니다..." />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>