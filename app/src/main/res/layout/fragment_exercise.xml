<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:scaleX="-1"
        app:implementationMode="compatible"
        android:layout_width="0dp" android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/iv_camera_frame"
        android:visibility="gone"
        android:scaleType="centerCrop"
        android:contentDescription="@null"
        android:layout_width="0dp" android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />

    <com.fallzero.app.ui.overlay.PoseOverlayView
        android:id="@+id/pose_overlay"
        android:scaleX="-1"
        android:layout_width="0dp" android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />

    <com.fallzero.app.ui.overlay.GuideBarView
        android:id="@+id/guide_bar"
        android:layout_width="0dp" android:layout_height="0dp"
        android:layout_marginTop="140dp" android:layout_marginBottom="80dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />

    <com.fallzero.app.ui.overlay.BalanceBubbleView
        android:id="@+id/guide_bubble"
        android:layout_width="320dp" android:layout_height="320dp"
        android:layout_marginTop="80dp" android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_exercise_name"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:textSize="20sp" android:textColor="#FFFF00"
        android:background="#CC000000" android:padding="10dp"
        android:gravity="center" android:layout_marginTop="16dp"
        android:maxLines="1" android:ellipsize="end"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/btn_camera_flip"
        app:layout_constraintEnd_toStartOf="@id/btn_stop" />

    <TextView
        android:id="@+id/tv_count"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="0 / 0" android:textSize="28sp" android:textStyle="bold"
        android:textColor="#FFFF00" android:background="#CC000000"
        android:paddingLeft="14dp" android:paddingRight="14dp"
        android:paddingTop="8dp" android:paddingBottom="8dp"
        android:layout_marginTop="8dp" android:layout_marginEnd="12dp"
        app:layout_constraintTop_toBottomOf="@id/btn_stop"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_camera_flip"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="48dp" android:layout_height="48dp"
        android:layout_marginTop="16dp" android:layout_marginStart="12dp"
        android:text="🔄" android:textSize="22sp" android:textColor="#FFFFFF"
        android:backgroundTint="#80000000"
        android:insetTop="0dp" android:insetBottom="0dp" android:padding="0dp"
        app:cornerRadius="24dp"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_big_countdown"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="120sp" android:textStyle="bold" android:textColor="#FFFF00"
        android:shadowColor="#000000" android:shadowDx="2" android:shadowDy="2" android:shadowRadius="6"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
        tools:text="3" />

    <TextView
        android:id="@+id/tv_error_message"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="22sp" android:textStyle="bold" android:textColor="#FFFF00"
        android:background="#CC000000"
        android:paddingLeft="20dp" android:paddingRight="20dp"
        android:paddingTop="10dp" android:paddingBottom="10dp"
        android:gravity="center" android:lineSpacingMultiplier="1.2"
        android:visibility="gone" android:layout_marginBottom="120dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_debug_count"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="DEBUG +1" android:textSize="14sp"
        android:visibility="gone" android:backgroundTint="#80FF9800"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_stop"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="48dp" android:layout_height="48dp"
        android:layout_marginTop="16dp" android:layout_marginEnd="12dp"
        android:text="✕" android:textSize="22sp" android:textStyle="bold" android:textColor="#FF5252"
        android:backgroundTint="#80000000"
        android:insetTop="0dp" android:insetBottom="0dp" android:padding="0dp"
        app:cornerRadius="24dp"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintEnd_toEndOf="parent" />

    <!-- 세션 완료 오버레이 -->
    <FrameLayout
        android:id="@+id/session_complete_overlay"
        android:layout_width="0dp" android:layout_height="0dp"
        android:background="#F0000000" android:clickable="true" android:focusable="true"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center" android:orientation="vertical" android:gravity="center"
            android:paddingLeft="32dp" android:paddingRight="32dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="★" android:textSize="80sp" android:textColor="#FFFF00" android:gravity="center" />
            <TextView android:id="@+id/tv_session_complete_title"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="20dp" android:text="오늘 운동을 모두 마치셨어요!"
                android:textSize="28sp" android:textStyle="bold" android:textColor="#FFFF00" android:gravity="center" />
            <TextView android:id="@+id/tv_session_complete_subtitle"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="16dp" android:text="수고하셨어요. 잠시 후 홈으로 돌아갑니다."
                android:textSize="20sp" android:textColor="#FFE066" android:gravity="center" />
        </LinearLayout>
    </FrameLayout>

    <!-- 일시정지 오버레이 -->
    <FrameLayout
        android:id="@+id/pause_overlay"
        android:layout_width="0dp" android:layout_height="0dp"
        android:background="#A0000000" android:clickable="true" android:focusable="true"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⏸" android:textSize="64sp" android:gravity="center" />
            <TextView android:id="@+id/tv_pause_message"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="16dp" android:text="카메라 앞으로 와주세요"
                android:textSize="28sp" android:textStyle="bold" android:textColor="#FFFF00" android:gravity="center" />
        </LinearLayout>
    </FrameLayout>

    <!-- 안내 영상 오버레이 -->
    <FrameLayout
        android:id="@+id/guidance_overlay"
        android:layout_width="0dp" android:layout_height="0dp"
        android:background="#FF000000"
        android:clickable="true" android:focusable="true"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- 상단 운동 이름 (검사 세션의 tv_guidance_title과 동일 스타일) -->
            <TextView
                android:id="@+id/tv_guidance_title"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginLeft="20dp" android:layout_marginRight="20dp"
                android:breakStrategy="simple" android:hyphenationFrequency="none"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="16sp" android:autoSizeMaxTextSize="32sp"
                android:autoSizeStepGranularity="2sp"
                android:textSize="32sp" android:textStyle="bold" android:textColor="#FFFF00"
                android:gravity="center" android:background="#EE000000"
                android:paddingLeft="16dp" android:paddingRight="16dp"
                android:paddingTop="10dp" android:paddingBottom="10dp"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:text="앉아서 무릎 펴기" />

            <!-- 중앙 "안내 영상" 텍스트 (검사 세션의 tv_video_placeholder와 동일 스타일) -->
            <TextView
                android:id="@+id/tv_video_placeholder"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="@string/guidance_video_placeholder"
                android:textColor="#CCCC00"
                android:textSize="28sp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/tv_guidance_title"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- 전체화면 안내 영상 -->
            <TextureView
                android:id="@+id/video_exercise_guide"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/tv_guidance_title"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- 자막 오버레이: 전체 반투명 배경 + 하단 자막 -->
        <FrameLayout
            android:id="@+id/guide_text_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#B3000000"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_guide_line_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="32dp"
                android:layout_marginEnd="32dp"
                android:textSize="48sp"
                android:textStyle="bold"
                android:textColor="#FFFF00"
                android:gravity="center"
                android:lineSpacingMultiplier="1.25"
                android:maxLines="4"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="20sp"
                android:autoSizeMaxTextSize="48sp"
                android:autoSizeStepGranularity="2sp"
                android:shadowColor="#000000"
                android:shadowDx="4"
                android:shadowDy="4"
                android:shadowRadius="8"
                tools:text="의자나 벽을 한 손으로\n가볍게 잡고 서주세요" />

        </FrameLayout>

    </FrameLayout>

    <!-- 동작 전환 오버레이 -->
    <FrameLayout
        android:id="@+id/exercise_instruction_overlay"
        android:layout_width="0dp" android:layout_height="0dp"
        android:background="#AA000000" android:clickable="true" android:focusable="true"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_exercise_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:textSize="40sp"
            android:textStyle="bold"
            android:textColor="#FFFF00"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            tools:text="다른 쪽 다리로\n바꿔주세요" />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>