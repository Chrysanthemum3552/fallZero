<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="24dp">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_back"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="52dp"
        android:text="← 뒤로"
        android:textSize="22sp"
        android:textColor="@color/text_primary"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_question"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="나이가 어떻게\n되시나요?"
        android:breakStrategy="simple"
        android:hyphenationFrequency="none"
        android:textSize="40sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:lineSpacingMultiplier="1.15"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btn_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="음성으로 말하거나 아래 칸을 눌러 \n입력하세요"
        android:breakStrategy="simple"
        android:hyphenationFrequency="none"
        android:textSize="22sp"
        android:textColor="@color/text_secondary"
        android:lineSpacingMultiplier="1.25"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tv_question"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 큰 숫자 디스플레이: subtitle 아래로만 흐르게 (위→아래 단방향) -->
    <TextView
        android:id="@+id/tv_age_display"
        android:layout_width="231dp"
        android:layout_height="131dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_age_display"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:minWidth="200dp"
        android:paddingLeft="36dp"
        android:paddingTop="4dp"
        android:paddingRight="36dp"
        android:paddingBottom="4dp"
        android:singleLine="true"
        android:text="—"
        android:textColor="@color/text_primary"
        android:textSize="64sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle" />

    <TextView
        android:id="@+id/tv_voice_status"
        android:layout_width="337dp"
        android:layout_height="76dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:breakStrategy="simple"
        android:gravity="center"
        android:hyphenationFrequency="none"
        android:text="🎤 듣고 있어요"
        android:textColor="#FFC107"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/btn_manual_input"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_age_display" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_manual_input"
        android:layout_width="332dp"
        android:layout_height="87dp"
        android:layout_marginLeft="24dp"
        android:layout_marginRight="24dp"
        android:layout_marginBottom="16dp"
        android:text="입력"
        android:textColor="@color/on_primary"
        android:textSize="28sp"
        android:textStyle="bold"
        app:backgroundTint="@color/primary"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
