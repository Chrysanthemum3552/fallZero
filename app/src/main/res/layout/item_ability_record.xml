<?xml version="1.0" encoding="utf-8"?>
<!-- 1 페이지 = 1 record. 단순 진급 룰에 맞춘 반복별 음성피드백 트래커.
     상단: 날짜·요약 / 하단: R1~Rn 셀 그리드 (초록=피드백 없음, 주황=피드백 발생, 어두움=미수행). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp">

    <!-- 헤더: 날짜 + 결과 한 줄 요약 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_summary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            tools:text="잘 따라하셨어요" />

        <TextView
            android:id="@+id/tv_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginStart="8dp"
            tools:text="2026-06-04 (목)" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/text_secondary"
        android:alpha="0.2"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="10dp" />

    <!-- 라벨 + 범례 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="반복별 수행"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_rep_cell_good" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="잘함"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="10dp" />

        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_rep_cell_feedback" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="안내 발생"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- 반복 셀 그리드 — 어댑터가 동적으로 채움. 빈 LinearLayout(vertical)이 row 컨테이너. -->
    <LinearLayout
        android:id="@+id/layout_reps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="10dp" />

    <!-- 진급 조건 안내 — 결과에 따라 어댑터가 텍스트·색상 갱신. -->
    <TextView
        android:id="@+id/tv_progression_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp"
        tools:text="모든 반복에서 안내 없이 잘 수행했어요 — 다음 단계 진급!" />

</LinearLayout>