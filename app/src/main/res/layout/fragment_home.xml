<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 인사 -->
        <TextView
            android:id="@+id/tv_greeting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="안녕하세요!"
            android:textSize="44sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="16dp" />

        <!-- 대시보드 카드 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- 연속 운동일 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🔥 연속 운동"
                        android:textSize="40sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tv_streak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0일"
                        android:textSize="44sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#333333"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp" />

                <!-- 낙상 위험 등급 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="⚠️ 낙상 위험 등급"
                        android:textSize="40sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tv_risk_level"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="검사 필요"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:background="@drawable/bg_risk_level"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#333333"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp" />

                <!-- 오늘 운동 상태 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="✅ 오늘 운동"
                        android:textSize="40sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tv_today_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="아직 안 했어요"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:textColor="@color/warning" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 운동 시작 (메인 버튼) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start_exercise"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:text="@string/home_start_exercise"
            android:textSize="40sp"
            android:textColor="@color/on_primary"
            android:layout_marginTop="24dp"
            app:backgroundTint="@color/primary"
            app:cornerRadius="16dp" />

        <!-- 낙상 위험 검사 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start_exam"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:text="@string/home_start_exam"
            android:textSize="40sp"
            android:textColor="@color/primary"
            android:layout_marginTop="16dp"
            app:backgroundTint="@color/surface"
            app:strokeColor="@color/primary"
            app:strokeWidth="2dp"
            app:cornerRadius="16dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <!-- 내 리포트 보기 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_view_report"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:text="@string/home_view_report"
            android:textSize="40sp"
            android:textColor="@color/primary"
            android:layout_marginTop="16dp"
            app:backgroundTint="@color/surface"
            app:strokeColor="@color/primary"
            app:strokeWidth="2dp"
            app:cornerRadius="16dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <!-- 보호자에게 공유 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_share_guardian"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:text="@string/home_share_guardian"
            android:textSize="40sp"
            android:textColor="@color/primary"
            android:layout_marginTop="16dp"
            app:backgroundTint="@color/surface"
            app:strokeColor="@color/primary"
            app:strokeWidth="2dp"
            app:cornerRadius="16dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <!-- TV로 보내기 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cast_tv"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:text="@string/home_cast_tv"
            android:textSize="40sp"
            android:textColor="@color/primary"
            android:layout_marginTop="16dp"
            app:backgroundTint="@color/surface"
            app:strokeColor="@color/primary"
            app:strokeWidth="2dp"
            app:cornerRadius="16dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <!-- 설정 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_settings"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="@string/home_settings"
            android:textSize="36sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp"
            app:backgroundTint="@android:color/transparent"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

    </LinearLayout>
</ScrollView>