<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:padding="20dp">

    <!-- 탭 세그먼트: surface pill 안에 두 옵션 동등 배치, active만 primary fill -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_tab_today"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="오늘 운동"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/on_primary"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="@color/primary"
                app:cornerRadius="12dp"
                app:strokeWidth="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_tab_menu"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="메뉴"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="12dp"
                app:strokeWidth="0dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- 오늘 운동 탭 -->
        <ScrollView
            android:id="@+id/tab_today_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 메인 CTA: 2줄 카드 — 무슨 일이 일어날지 메타 라인 제공 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_start_exercise"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/primary"
                    app:rippleColor="#33000000">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingTop="18dp"
                        android:paddingBottom="18dp"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp">

                        <TextView
                            android:id="@+id/tv_start_exercise_main"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="▶ 운동 시작하기"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_primary"
                            android:includeFontPadding="false"
                            android:maxLines="1" />

                        <TextView
                            android:id="@+id/tv_start_exercise_meta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="약 15분 · 8가지 동작"
                            android:textSize="15sp"
                            android:textColor="#B3000000"
                            android:layout_marginTop="6dp"
                            android:maxLines="1" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 대시보드: 3분할 카드 (divider 제거, 8dp gap, 숫자 위계 강화, 세 카드 높이 통일) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:orientation="horizontal"
                    android:layout_marginTop="14dp">

                    <!-- 연속 운동 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/surface">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="연속 운동"
                                android:textSize="14sp"
                                android:textColor="@color/text_secondary"
                                android:maxLines="1"
                                android:ellipsize="end" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="bottom"
                                android:layout_marginTop="6dp">

                                <TextView
                                    android:id="@+id/tv_streak"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="32sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/primary"
                                    android:includeFontPadding="false"
                                    android:maxLines="1" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="일"
                                    android:textSize="16sp"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginStart="3dp"
                                    android:layout_marginBottom="4dp" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 위험 등급 (검사 미수행 시 카드 stroke 강조) -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_risk"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/surface">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="위험 등급"
                                android:textSize="14sp"
                                android:textColor="@color/text_secondary"
                                android:maxLines="1"
                                android:ellipsize="end" />

                            <TextView
                                android:id="@+id/tv_risk_level"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="검사 필요"
                                android:textStyle="bold"
                                android:textColor="@color/warning"
                                android:gravity="center"
                                android:layout_marginTop="14dp"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:includeFontPadding="false"
                                app:autoSizeTextType="uniform"
                                app:autoSizeMinTextSize="18sp"
                                app:autoSizeMaxTextSize="28sp"
                                app:autoSizeStepGranularity="1sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 오늘 운동 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/surface">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="오늘 운동"
                                android:textSize="14sp"
                                android:textColor="@color/text_secondary"
                                android:maxLines="1"
                                android:ellipsize="end" />

                            <TextView
                                android:id="@+id/tv_today_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0/8"
                                android:textSize="32sp"
                                android:textStyle="bold"
                                android:textColor="@color/warning"
                                android:gravity="center"
                                android:includeFontPadding="false"
                                android:layout_marginTop="6dp"
                                android:maxLines="1" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- 체크리스트 헤더: 진행도 인라인 표시 + ProgressBar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="오늘의 운동"
                        android:breakStrategy="simple"
                        android:hyphenationFrequency="none"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tv_today_progress_inline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 / 8"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:maxLines="1" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/pb_today_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="6dp"
                    android:max="8"
                    android:progress="0"
                    android:progressTint="@color/primary"
                    android:progressBackgroundTint="@color/surface" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/surface">

                    <LinearLayout
                        android:id="@+id/checklist_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingLeft="14dp"
                        android:paddingRight="14dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </ScrollView>

        <!-- 메뉴 탭 -->
        <ScrollView
            android:id="@+id/tab_menu_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_start_exam"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:text="@string/home_start_exam"
                    android:textSize="22sp"
                    android:textColor="@color/primary"
                    app:backgroundTint="@color/surface"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="2dp"
                    app:cornerRadius="14dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_view_report"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:text="@string/home_view_report"
                    android:textSize="22sp"
                    android:textColor="@color/primary"
                    android:layout_marginTop="14dp"
                    app:backgroundTint="@color/surface"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="2dp"
                    app:cornerRadius="14dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_cast_tv"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:text="@string/home_cast_tv"
                    android:textSize="22sp"
                    android:textColor="@color/primary"
                    android:layout_marginTop="14dp"
                    app:backgroundTint="@color/surface"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="2dp"
                    app:cornerRadius="14dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_settings"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="@string/home_settings"
                    android:textSize="22sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="14dp"
                    app:backgroundTint="@android:color/transparent"
                    style="@style/Widget.MaterialComponents.Button.TextButton" />

            </LinearLayout>
        </ScrollView>

    </FrameLayout>

</LinearLayout>