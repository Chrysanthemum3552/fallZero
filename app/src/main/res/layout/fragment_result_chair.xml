<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_step"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="3 / 4"
        android:breakStrategy="simple"
        android:hyphenationFrequency="none"
        android:textSize="22sp"
        android:textColor="#888888"
        android:gravity="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="의자 일어서기 결과"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#FFFF00"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tv_step"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/chart_box"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#2A2A2A"
        android:padding="20dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="안전 기준 (연령·성별 기준)"
            android:breakStrategy="simple"
            android:hyphenationFrequency="none"
            android:textSize="20sp"
            android:textColor="#FFFF00" />
        <ProgressBar
            android:id="@+id/pb_norm"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:layout_marginTop="6dp"
            android:max="12"
            android:progress="12"
            android:progressTint="#FFFF00"
            android:progressBackgroundTint="#444444" />
        <TextView
            android:id="@+id/tv_norm_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:breakStrategy="simple"
            android:hyphenationFrequency="none"
            android:textSize="22sp"
            android:textColor="#FFFF00" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="사용자 결과"
            android:breakStrategy="simple"
            android:hyphenationFrequency="none"
            android:textSize="20sp"
            android:textColor="#AAAAAA" />
        <ProgressBar
            android:id="@+id/pb_user"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:layout_marginTop="6dp"
            android:max="12"
            android:progress="0"
            android:progressTint="#00FF88"
            android:progressBackgroundTint="#444444" />
        <TextView
            android:id="@+id/tv_user_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:breakStrategy="simple"
            android:hyphenationFrequency="none"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_judgement"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:breakStrategy="simple"
        android:hyphenationFrequency="none"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="20dp"
        android:padding="16dp"
        android:lineSpacingMultiplier="1.3"
        app:layout_constraintTop_toBottomOf="@id/chart_box"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="의자 일어서기에서 위험 신호가 있어요" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_next"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:text="다음"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:enabled="false"
        android:layout_marginBottom="24dp"
        app:backgroundTint="#FFFF00"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>