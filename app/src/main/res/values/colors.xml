<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- WCAG 2.1 AAA 기준 적용 -->
    <!-- 검정 배경 + 노란색 조합 (명도 대비 19.6:1, 기준 7:1 이상) -->

    <color name="primary">#FFFF00</color>
    <color name="primary_dark">#CCCC00</color>
    <color name="primary_light">#FFFF99</color>
    <color name="accent">#FFFF00</color>

    <!-- 배경: 검정 -->
    <color name="background">#000000</color>
    <color name="surface">#1A1A1A</color>
    <color name="on_primary">#000000</color>
    <color name="on_background">#FFFF00</color>
    <color name="on_surface">#FFFF00</color>

    <!-- 텍스트: 노란색 계열 -->
    <color name="text_primary">#FFFF00</color>
    <color name="text_secondary">#FFE066</color>
    <color name="text_hint">#CCAA00</color>

    <!-- 상태 색상 (검정 배경 위에서 잘 보이도록) -->
    <color name="success">#00FF88</color>
    <color name="warning">#FF9900</color>
    <color name="error">#FF4444</color>

    <!-- Pose overlay -->
    <color name="landmark_color">#FFFF00</color>
    <color name="connection_color">#00FFFF</color>
</resources>