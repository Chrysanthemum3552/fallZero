<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- WCAG 2.1 AAA 기준 테마 - 검정 배경 + 노란색 -->
    <style name="Theme.FallZero" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">40sp</item>
        <!-- 버튼 텍스트 색상 -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <!-- 한국어 줄바꿈: 어절 중간에 끊기지 않도록. 모든 TextView 기본 적용 -->
        <item name="android:textViewStyle">@style/AppTextView</item>
    </style>

    <!-- 한국어 줄바꿈 처리: simple + hyphenation 끔. "낙상 위/험군" 같은 어색한 분할 방지 -->
    <style name="AppTextView" parent="android:Widget.TextView">
        <item name="android:breakStrategy">simple</item>
        <item name="android:hyphenationFrequency">none</item>
    </style>

    <style name="Theme.FallZero.NoActionBar" parent="Theme.FallZero">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- 큰 버튼 스타일 (30pt 이상) -->
    <style name="Widget.FallZero.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textSize">40sp</item>
        <item name="android:minHeight">72dp</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/on_primary</item>
    </style>
</resources>